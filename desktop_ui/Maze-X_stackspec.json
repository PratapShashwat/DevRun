{
  "schema_version": "1.0",
  "project_name": "Maze-X",
  "workspace": {
    "root_fs": "/var/lib/stackstore/environments/Maze-X",
    "network": {
      "exposed_ports": [],
      "internal_routing": true
    }
  },
  "services": [
    {
      "service_name": "arduino-firmware",
      "context_dir": ".",
      "runtime": {
        "language": "C++",
        "version": "Arduino",
        "manager": "Arduino IDE"
      },
      "commands": {
        "install": null,
        "build": "arduino-cli compile --fqbn arduino:avr:uno .",
        "start": "arduino-cli upload --fqbn arduino:avr:uno -p \"$ARDUINO_PORT\" ."
      },
      "env_vars": {
        "ARDUINO_PORT": "<REQUIRED_USER_INPUT>"
      }
    }
  ]
}